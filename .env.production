# Build-time public config for the production build (Azure SWA runs `next build`).
# NEXT_PUBLIC_ vars are inlined at build time — this must be present during the build, which is why
# it lives here (committed) rather than as a runtime/SWA setting. Non-secret: just the
# Cloudflare-fronted RAG API origin. For local dev against a local API, override via .env.local.
NEXT_PUBLIC_API_BASE_URL=https://ama-api.nicjranum.uk
